# Backend
APP_NAME=KubeSight AI
APP_ENV=development
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_PORT=8000

# Database
POSTGRES_USER=kubesight
POSTGRES_PASSWORD=kubesight
POSTGRES_DB=kubesight
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://kubesight:kubesight@localhost:5432/kubesight

# Kubernetes
KUBECONFIG_PATH=
KUBERNETES_CONTEXT=
MONITORED_CLUSTER_NAME=local-cluster

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_REQUEST_TIMEOUT_SECONDS=60
OLLAMA_PORT=11434

# Frontend
VITE_API_BASE_URL=http://localhost:8000
